PORT=8930
SQLITE_PATH=./data/langchain.sqlite

# Agnes uses an OpenAI-compatible chat completions API.
OPENAI_API_KEY=replace-with-your-key
OPENAI_BASE_URL=https://apihub.agnes-ai.com/v1
OPENAI_MODEL=agnes-2.0-flash

AGNES_API_KEY=replace-with-your-key
AGNES_BASE_URL=https://apihub.agnes-ai.com
AGNES_IMAGE_MODEL=agnes-image-2.0-flash
AGNES_VIDEO_MODEL=agnes-video-v2.0
AGNES_CHAT_TIMEOUT_MS=120000
AGNES_VIDEO_TIMEOUT_MS=900000

BITIFUL_ACCESS_KEY=replace-with-your-access-key
BITIFUL_SECRET_KEY=replace-with-your-secret-key
BITIFUL_BUCKET=replace-with-your-bucket
BITIFUL_ENDPOINT=https://s3.bitiful.net
BITIFUL_REGION=cn-east-1
BITIFUL_OBJECT_PREFIX=langchain/generated
BITIFUL_PRESIGN_TTL_SECONDS=3600
